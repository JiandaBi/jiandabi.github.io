@article{huang2025risk,
	abbr={Front. Public Health},
	title={Risk Factors for Hospital Readmission of Multidrug-Resistant Tuberculosis: Evidence of Longitudinal Follow-Up Data in Ningbo, China},
	author={Huang, Jinying and Sang, Guoxin and Bi, Jianda and Che, Yang and Lin, Yi},
	journal={Frontiers in Public Health},
	volume={13},
	year={2025},
	doi={10.3389/fpubh.2025.1657931},
	abstract={Using a retrospective longitudinal design with 337 MDR-TB patients and 1,255 hospitalization records (median follow-up: 46 months) in Ningbo, China (2015–2021), this study examines risk factors for rehospitalization. Standard Cox and extended Cox models (Andersen-Gill, PWP-TT, Frailty) reveal that younger age and urban residence are protective against readmission, while outdoor service work, migrant status, and Group B medication use increase readmission risk.},
	issn={2296-2565},
	langid={english},
	my_type={publications}
}

@article{hua2023appropriate,
	abbr={CEQI},
	title={The Appropriate Level of Financial Inclusion: The Perspective of Financial Stability},
	author={Hua, Xiuping and Bi*, Jianda and Shi, Haoqian},
	journal={China Economic Quarterly International},
	volume={3},
	number={3},
	pages={167--182},
	year={2023},
	doi={10.1016/j.ceqi.2023.08.001},
	issn={2666-9331},
	abstract={This paper constructs a global financial inclusion index using data from the World Bank, IMF, and V-Lab covering 115 countries and regions, and examines the relationship between financial inclusion and financial stability. The findings reveal an inverted U-shaped relationship between financial inclusion development and financial stability, and effective macro-regulation can mitigate the systemic risk brought by financial inclusion. The constructed index and variables such as capital adequacy ratio and bank market power can be used to simulate and predict financial crises, providing a model basis and decision-making reference for financial regulatory authorities.},
	annotation={* Corresponding author},
	langid={english},
	my_type={publications}
}
